# Supply-chain hardening: never run npm/pnpm lifecycle scripts (preinstall,
# postinstall, prepare, ...) for any dependency. This is one of the most
# common npm supply-chain attack vectors. pnpm 10+ already blocks unknown
# packages by default; this makes the intent explicit and applies if anyone
# falls back to npm or pnpm < 10.
#
# We don't rely on any dependency's lifecycle scripts:
# - @playwright/test downloads browsers via the explicit `playwright install`
#   command, not on postinstall.
ignore-scripts=true

# Refuse to install any package version that was published less than this
# many minutes ago. Most quickly-discovered npm supply-chain incidents
# (account takeover, malicious update, dependency-confusion) are flagged
# and yanked within 1–48 hours. A 3-day quarantine catches almost all of
# them while keeping security-patch latency tolerable. pnpm 10.4+.
minimum-release-age=4320

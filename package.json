{
  "name": "kajitack-website",
  "private": true,
  "description": "Dev-only tooling (visual regression tests). Production site is plain HTML/CSS.",
  "packageManager": "pnpm@11.1.3",
  "volta": {
    "node": "22.15.1"
  },
  "scripts": {
    "serve": "python3 -m http.server 8000",
    "og:generate": "node tools/og/generate.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}

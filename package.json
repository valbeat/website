{
  "name": "kajitack-website",
  "private": true,
  "description": "Personal site built with Astro (static output). Deployed to Cloudflare Workers.",
  "packageManager": "pnpm@11.1.3",
  "volta": {
    "node": "22.15.1"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && pnpm lint:style",
    "lint:style": "stylelint --allow-empty-input \"{src,tokens}/**/*.css\"",
    "og:generate": "node tools/og/generate.mjs",
    "tokens:build": "style-dictionary build --config tokens/config.mjs",
    "tokens:check": "node tokens/check-contrast.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "astro": "^7.0.9",
    "style-dictionary": "4.4.0",
    "stylelint": "17.14.0",
    "stylelint-declaration-strict-value": "1.11.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.1"
  }
}
